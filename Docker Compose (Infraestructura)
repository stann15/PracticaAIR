# docker-compose.yml
version: '3.8'

services:
  api:
    build: .
    ports:
      - "5000:5000"
    environment:
      - POSTGRES_USER=senda_admin
      - POSTGRES_PASSWORD=password_segura
      - POSTGRES_DB=senda_urjc
      - POSTGRES_HOST=db
    depends_on:
      db:
        condition: service_healthy

  db:
    image: postgis/postgis:15-3.4
    environment:
      - POSTGRES_USER=senda_admin
      - POSTGRES_PASSWORD=password_segura
      - POSTGRES_DB=senda_urjc
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U senda_admin -d senda_urjc"]
      interval: 10s
      timeout: 5s
      retries: 5
    volumes:
      - pgdata:/var/lib/postgresql/data

volumes:
  pgdata:
